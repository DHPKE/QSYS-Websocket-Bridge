  local ctrls = {}
  
  -- Connection settings
  table.insert(ctrls, {
    Name = "Server_Host",
    ControlType = "Text",
    PinStyle = "Both",
    UserPin = true,
    Count = 1
  })
  
  table.insert(ctrls, {
    Name = "Server_Port",
    ControlType = "Text",
    PinStyle = "Both",
    UserPin = true,
    Count = 1
  })
  
  table.insert(ctrls, {
    Name = "Server_URL",
    ControlType = "Text",
    PinStyle = "Both",
    UserPin = true,
    Count = 1
  })
  
  table.insert(ctrls, {
    Name = "Use_SSL",
    ControlType = "Button",
    ButtonType = "Toggle",
    PinStyle = "Both",
    UserPin = true,
    Count = 1
  })
  
  -- Connection control
  table.insert(ctrls, {
    Name = "Connect",
    ControlType = "Button",
    ButtonType = "Trigger",
    PinStyle = "Input",
    UserPin = true,
    Count = 1
  })
  
  table.insert(ctrls, {
    Name = "Disconnect",
    ControlType = "Button",
    ButtonType = "Trigger",
    PinStyle = "Input",
    UserPin = true,
    Count = 1
  })
  
  -- Status monitoring
  table.insert(ctrls, {
    Name = "Status",
    ControlType = "Indicator",
    IndicatorType = "Status",
    PinStyle = "Output",
    UserPin = true,
    Count = 1
  })
  
  table.insert(ctrls, {
    Name = "Status_Text",
    ControlType = "Text",
    PinStyle = "Output",
    UserPin = true,
    Count = 1
  })
  
  table.insert(ctrls, {
    Name = "Connected",
    ControlType = "Indicator",
    IndicatorType = "Led",
    PinStyle = "Output",
    UserPin = true,
    Count = 1
  })
  
  -- Statistics
  table.insert(ctrls, {
    Name = "Messages_Sent",
    ControlType = "Text",
    PinStyle = "Output",
    UserPin = true,
    Count = 1
  })
  
  table.insert(ctrls, {
    Name = "Messages_Received",
    ControlType = "Text",
    PinStyle = "Output",
    UserPin = true,
    Count = 1
  })
  
  table.insert(ctrls, {
    Name = "Errors",
    ControlType = "Text",
    PinStyle = "Output",
    UserPin = true,
    Count = 1
  })
  
  -- Debug level
  table.insert(ctrls, {
    Name = "Debug_Level",
    ControlType = "Text",
    PinStyle = "Both",
    UserPin = true,
    Count = 1
  })
  
  return ctrls
end

-- Plugin layout
