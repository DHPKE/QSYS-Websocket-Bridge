  layout["Messages_Sent"] = {
    PrettyName = "Stats~Messages Sent",
    Style = "Text",
    Position = { x + labelWidth, y },
    Size = { 80, 20 }
  }
  
  y = y + 25
  
  table.insert(graphics, {
