  layout["Connected"] = {
    PrettyName = "Status~Connected LED",
    Style = "Led",
    Position = { x + labelWidth, y },
    Size = { 20, 20 }
  }
  
  layout["Status"] = {
    PrettyName = "Status~Indicator",
    Style = "Indicator",
