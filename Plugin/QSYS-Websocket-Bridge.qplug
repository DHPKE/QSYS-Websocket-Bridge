  local x = 10
  local y = 10
  local rowHeight = 30
  local labelWidth = 120
  local controlWidth = 200
  
  -- Title
  table.insert(graphics, {
    Type = "GroupBox",
    Text = "WebSocket Bridge Configuration",
    Fill = { 245, 245, 250 },
    StrokeWidth = 1,
    CornerRadius = 4,
    Position = { 0, 0 },
    Size = { 350, 450 }
  })
  
  y = 30
  
  -- Server settings
  table.insert(graphics, {
    Type = "Label",
    Text = "Server Host:",
    Position = { x, y },
    Size = { labelWidth, 20 }
  })
  
  layout["Server_Host"] = {
    PrettyName = "Server~Host",
    Style = "Text",
    Position = { x + labelWidth, y },
    Size = { controlWidth, 20 }
  }
  
  y = y + rowHeight
  
  table.insert(graphics, {
    Type = "Label",
    Text = "Server Port:",
    Position = { x, y },
    Size = { labelWidth, 20 }
  })
  
  layout["Server_Port"] = {
    PrettyName = "Server~Port",
    Style = "Text",
    Position = { x + labelWidth, y },
    Size = { controlWidth, 20 }
  }
  
  y = y + rowHeight
  
  table.insert(graphics, {
    Type = "Label",
    Text = "Server URL:",
    Position = { x, y },
    Size = { labelWidth, 20 }
  })
  
  layout["Server_URL"] = {
    PrettyName = "Server~URL",
