-- Q-SYS WebSocket Bridge Plugin
-- Universal bidirectional communication bridge between Q-SYS and external systems
-- No Named Controls required - direct component access via Component.New()

PluginInfo = {
  Name = "PKE~WebSocket Bridge",
  Version = "1.0",
  BuildVersion = "1.0.0.0",
  Id = "9f2e8b3d-4c5a-6b7d-8e9f-0a1b2c3d4e5f",
  Author = "DHPKE",
  Description = "WebSocket Bridge - Direct component access without Named Controls"
}

function GetColor(props)
  return { 66, 135, 245 }  -- Blue
end

function GetPrettyName(props)
  return "WebSocket Bridge v1.0"
end

-- No properties needed - configuration via controls
function GetProperties()
  return {}
end

-- No UI pages needed for this plugin
function GetPages(props)
  return { { name = "Config" } }
end

-- Controls for configuration and monitoring
