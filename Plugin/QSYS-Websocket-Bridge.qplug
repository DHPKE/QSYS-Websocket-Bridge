  return layout, graphics
end

-- Runtime script starts here
if Controls then
  
  -- Global variables (module scope, NOT local!)
  ws = nil  -- WebSocket object
  pingTimer = Timer.New()
  reconnectTimer = Timer.New()
  
  -- Component cache
  componentCache = {}  -- { componentName = { component, controls } }
  subscriptions = {}   -- { "component:control" = [clientIds] }
  
  -- Statistics
  local messagesSent = 0
  local messagesReceived = 0
  local errors = 0
  
  -- Configuration
  local debugLevel = "Errors"  -- "None", "Errors", "All"
  local reconnectDelay = 5
  local pingInterval = 10
  
  -- Helper: Debug print
  local function dprint(level, message)
    if debugLevel == "All" or (debugLevel == "Errors" and level == "Error") then
      print(string.format("[%s] %s", level, message))
    end
  end
  
  -- Helper: Update status
  local function SetStatus(state, text)
    Controls.Status.Value = state  -- 0=OK, 1=Compromised, 2=Fault, 5=Not Present
    Controls.Status_Text.String = text
    Controls.Connected.Boolean = (state == 0)
    dprint("Info", "Status: " .. text)
  end
  
  -- Helper: Update statistics
  local function UpdateStats()
    Controls.Messages_Sent.String = tostring(messagesSent)
    Controls.Messages_Received.String = tostring(messagesReceived)
    Controls.Errors.String = tostring(errors)
  end
  
  -- Get or create component reference
  local function GetComponent(componentName)
    if not componentCache[componentName] then
      local success, comp = pcall(Component.New, componentName)
      if success and comp then
        componentCache[componentName] = {
          component = comp,
          controls = {}
        }
        dprint("Info", "Component cached: " .. componentName)
      else
        dprint("Error", "Component not found: " .. componentName)
        return nil
      end
    end
    return componentCache[componentName]
  end
  
  -- Get component control
  local function GetControl(componentName, controlName)
    local compData = GetComponent(componentName)
    if not compData then return nil end
    
    local comp = compData.component
    if comp[controlName] then
      return comp[controlName]
    else
      dprint("Error", string.format("Control '%s' not found in component '%s'", controlName, componentName))
      return nil
    end
  end
  
  -- Message handling
  local function HandleMessage(data)
    messagesReceived = messagesReceived + 1
    UpdateStats()
    
    local success, msg = pcall(rapidjson.decode, data)
    if not success then
      dprint("Error", "Failed to parse JSON: " .. tostring(data))
      errors = errors + 1
      UpdateStats()
      return
    end
    
    dprint("All", "Received: " .. rapidjson.encode(msg))
    
    local msgType = msg.type
    local id = msg.id
    
    -- Handle different message types
    if msgType == "get" then
      -- Get control value
      local control = GetControl(msg.component, msg.control)
      if control then
        local response = {
          id = id,
          type = "response",
          status = "ok",
          value = control.Value or control.String or control.Boolean
        }
        ws:Write(rapidjson.encode(response))
        messagesSent = messagesSent + 1
        UpdateStats()
      else
        local response = {
          id = id,
          type = "response",
          status = "error",
          error = "Control not found"
        }
        ws:Write(rapidjson.encode(response))
        messagesSent = messagesSent + 1
        errors = errors + 1
        UpdateStats()
      end
      
    elseif msgType == "set" then
      -- Set control value
      local control = GetControl(msg.component, msg.control)
      if control then
        if control.Value ~= nil then
          control.Value = msg.value
        elseif control.String ~= nil then
          control.String = tostring(msg.value)
        elseif control.Boolean ~= nil then
          control.Boolean = msg.value
        end
        
        local response = {
          id = id,
          type = "response",
          status = "ok"
        }
        ws:Write(rapidjson.encode(response))
        messagesSent = messagesSent + 1
        UpdateStats()
      else
        local response = {
          id = id,
          type = "response",
          status = "error",
          error = "Control not found"
        }
        ws:Write(rapidjson.encode(response))
        messagesSent = messagesSent + 1
        errors = errors + 1
        UpdateStats()
      end
      
    elseif msgType == "subscribe" then
      -- Subscribe to control changes
      local key = msg.component .. ":" .. msg.control
      subscriptions[key] = subscriptions[key] or {}
      table.insert(subscriptions[key], id)
      
      -- Set EventHandler for this control
      local control = GetControl(msg.component, msg.control)
      if control and not control.EventHandler then
        control.EventHandler = function(ctl)
          -- Notify all subscribers
          for _, subId in ipairs(subscriptions[key] or {}) do
            local update = {
              type = "update",
              subscription = subId,
              component = msg.component,
              control = msg.control,
              value = ctl.Value or ctl.String or ctl.Boolean,
              timestamp = os.time()
            }
            ws:Write(rapidjson.encode(update))
            messagesSent = messagesSent + 1
          end
          UpdateStats()
        end
      end
      
      local response = {
        id = id,
        type = "response",
        status = "ok"
      }
      ws:Write(rapidjson.encode(response))
      messagesSent = messagesSent + 1
      UpdateStats()
      
    elseif msgType == "unsubscribe" then
      -- Unsubscribe from control changes
      local key = msg.component .. ":" .. msg.control
      if subscriptions[key] then
        for i, subId in ipairs(subscriptions[key]) do
          if subId == id then
            table.remove(subscriptions[key], i)
            break
          end
        end
      end
      
      local response = {
        id = id,
        type = "response",
        status = "ok"
      }
      ws:Write(rapidjson.encode(response))
      messagesSent = messagesSent + 1
      UpdateStats()
      
    elseif msgType == "list" then
      -- List all components (placeholder - needs design file introspection)
      local components = {}
      for name, _ in pairs(componentCache) do
        table.insert(components, { name = name })
      end
      
      local response = {
        id = id,
        type = "response",
        status = "ok",
        components = components
      }
      ws:Write(rapidjson.encode(response))
      messagesSent = messagesSent + 1
      UpdateStats()
      
    else
      dprint("Error", "Unknown message type: " .. tostring(msgType))
      errors = errors + 1
      UpdateStats()
    end
  end
  
  -- WebSocket event handlers
  function ConnectWebSocket()
    if ws then
      dprint("Info", "Disconnecting existing connection")
      ws = nil
    end
    
    ws = WebSocket.New()
    
    ws.Connected = function()
      SetStatus(0, "Connected")
      pingTimer:Start(pingInterval)
      reconnectTimer:Stop()
      dprint("Info", "WebSocket connected")
    end
    
    ws.Data = function(ws, data)
      HandleMessage(data)
    end
    
    ws.Error = function(ws, err)
      SetStatus(2, "Error: " .. err)
      pingTimer:Stop()
      errors = errors + 1
      UpdateStats()
      dprint("Error", "WebSocket error: " .. err)
      
      -- Auto-reconnect
      reconnectTimer:Start(reconnectDelay)
    end
    
    ws.Closed = function()
      SetStatus(5, "Disconnected")
      pingTimer:Stop()
      dprint("Info", "WebSocket closed")
      
      -- Auto-reconnect
      reconnectTimer:Start(reconnectDelay)
    end
    
    ws.Pong = function()
      dprint("All", "Pong received")
    end
    
    -- Get connection settings
    local host = Controls.Server_Host.String or "localhost"
    local port = tonumber(Controls.Server_Port.String) or 3000
    local url = Controls.Server_URL.String or "/qsys"
    local useSSL = Controls.Use_SSL.Boolean
    local protocol = useSSL and "wss" or "ws"
    
    SetStatus(1, "Connecting...")
    dprint("Info", string.format("Connecting to %s://%s:%d%s", protocol, host, port, url))
    
    ws:Connect(protocol, host, url, port)
  end
  
  -- Ping timer
  pingTimer.EventHandler = function()
    if ws then
      ws:Ping()
    end
  end
  
  -- Reconnect timer
  reconnectTimer.EventHandler = function()
    dprint("Info", "Auto-reconnecting...")
    ConnectWebSocket()
  end
  
  -- Control event handlers
  Controls.Connect.EventHandler = function()
    ConnectWebSocket()
  end
  
  Controls.Disconnect.EventHandler = function()
    if ws then
      ws:Close()
      ws = nil
    end
    pingTimer:Stop()
    reconnectTimer:Stop()
    SetStatus(5, "Disconnected (manual)")
  end
  
  Controls.Debug_Level.EventHandler = function(ctl)
    debugLevel = ctl.String
    dprint("Info", "Debug level set to: " .. debugLevel)
  end
  
  -- Initialize
  Controls.Server_Host.String = "localhost"
  Controls.Server_Port.String = "3000"
  Controls.Server_URL.String = "/qsys"
  Controls.Use_SSL.Boolean = false
  Controls.Debug_Level.String = "Errors"
  
  SetStatus(5, "Not connected")
  UpdateStats()
  
  dprint("Info", "WebSocket Bridge initialized")
end
