# Server Configuration

# Server
PORT=3000
HOST=0.0.0.0
DEBUG=true

# WebSocket Paths
QSYS_PATH=/qsys
CLIENT_PATH=/client

# JWT Authentication
JWT_SECRET=change-this-secret-in-production-use-at-least-32-chars
JWT_EXPIRY=24h

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DB_PATH=./data/bridge.db

# Ping Interval (ms)
PING_INTERVAL=30000
